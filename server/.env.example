# ============================================================
# SERVER
# ============================================================
PORT=5000

# ============================================================
# DATABASE
# ============================================================
# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<app_name>

# ============================================================
# JWT SECRETS
# ============================================================
# Generate strong secrets with: openssl rand -hex 64
JWT_ACCESS_SECRET=<your_access_secret>
JWT_REFRESH_SECRET=<your_refresh_secret>
JWT_RESET_SECRET=<your_reset_secret>

# Token expiration (optional, set defaults in code if not used)
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_RESET_EXPIRES_IN=1h

# ============================================================
# URLS
# ============================================================
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ============================================================
# CLOUDINARY (File Storage)
# ============================================================
# Get credentials at: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# ============================================================
# MAIL SERVICE
# ============================================================
MAIL_SERVICE_URL=http://localhost:10000
